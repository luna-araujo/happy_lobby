{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch",
            "type": "godot",
            "request": "launch",
            "project": "${workspaceFolder}",
            "address": "127.0.0.1",
            "port": 6007,
            "scene": "main|current|pinned|<path>",
            // "editor_path": "c:\\Users\\Luna\\Godot\\editor\\Godot_v4.6-beta2_win64.exe\\Godot_v4.6-beta2_win64.exe",
            // engine command line flags
            "profiling": false,
            "single_threaded_scene": false,
            "debug_collisions": false,
            "debug_paths": false,
            "debug_navigation": false,
            "debug_avoidance": false,
            "debug_stringnames": false,
            "frame_delay": 0,
            "time_scale": 1.0,
            "disable_vsync": false,
            "fixed_fps": 30,
            // anything else
            "additional_options": ""
        },
        {
            "name": "Launch Main (Left Window)",
            "type": "godot",
            "request": "launch",
            "project": "${workspaceFolder}",
            "address": "127.0.0.1",
            "port": 6007,
            "scene": "main",
            "profiling": false,
            "single_threaded_scene": false,
            "debug_collisions": false,
            "debug_paths": false,
            "debug_navigation": false,
            "debug_avoidance": false,
            "debug_stringnames": false,
            "frame_delay": 0,
            "time_scale": 1.0,
            "disable_vsync": false,
            "fixed_fps": 30,
            "additional_options": "--windowed --resolution 960x1056 --position 0,24"
        },
        {
            "name": "Launch Main (Right Window)",
            "type": "godot",
            "request": "launch",
            "project": "${workspaceFolder}",
            "address": "127.0.0.1",
            "port": 6008,
            "scene": "main",
            "profiling": false,
            "single_threaded_scene": false,
            "debug_collisions": false,
            "debug_paths": false,
            "debug_navigation": false,
            "debug_avoidance": false,
            "debug_stringnames": false,
            "frame_delay": 0,
            "time_scale": 1.0,
            "disable_vsync": false,
            "fixed_fps": 30,
            "additional_options": "--windowed --resolution 960x1056 --position 960,24"
        }
    ],
    "compounds": [
        {
            "name": "Launch Main (Side by Side)",
            "configurations": [
                "Launch Main (Left Window)",
                "Launch Main (Right Window)"
            ],
            "stopAll": true
        }
    ]
}
